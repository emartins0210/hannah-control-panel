{
  "name": "agendador-fabolaservices-multicliente",
  "version": "2.0.0",
  "description": "Sistema inteligente de agendamento de limpeza multi-cliente com equipes - Fabíola Services",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "auth": "node server-auth.js",
    "auth-dev": "nodemon server-auth.js",
    "importar": "node importar-clientes-excel.js",
    "importar-custom": "node importar-clientes-excel.js",
    "docker-build": "docker build -t agendador-fabolaservices .",
    "docker-run": "docker run -p 3000:3000 -v $(pwd)/dados-clientes:/app/dados-clientes agendador-fabolaservices",
    "docker-compose": "docker-compose up",
    "test": "echo \"Tests pending\" && exit 0"
  },
  "keywords": [
    "agendamento",
    "limpeza",
    "multicliente",
    "multi-equipe",
    "inteligente",
    "scheduler",
    "fabiolservices"
  ],
  "author": "Fabíola Services",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.6",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.1.2",
    "nodemailer": "^8.0.3",
    "twilio": "^5.13.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fabolaservices/agendador-inteligente.git"
  },
