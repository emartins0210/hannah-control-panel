# ================================================
#  CleanAI SaaS — Environment Variables
#  Adicione estas variáveis no Railway:
#  railway.app → seu projeto → Variables
#  NUNCA compartilhe este arquivo publicamente
# ================================================

PORT=3000

# Sua chave master do Vapi.ai (Settings → API Keys)
VAPI_API_KEY=cole_sua_chave_aqui

# Chave secreta para proteger a API admin
ADMIN_SECRET=escolha_uma_senha_forte_aqui

# URL pública do servidor (depois de subir no Railway)
# Exemplo: https://cleanai-saas-production.up.railway.app
PUBLIC_URL=https://SEU-PROJETO.up.railway.app

# ── Twilio (WhatsApp notifications + urgent calls) ──────
# console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Twilio WhatsApp number
# Sandbox: whatsapp:+14155238886
# Production: whatsapp:+1XXXXXXXXXX (your approved Twilio number)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Fabíola's contact details
FABIOLA_WHATSAPP=+13215557880
FABIOLA_PHONE=+13215557880

# ── Google Calendar ─────────────────────────────────────
# console.cloud.google.com → Service Accounts → create → download JSON
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# ── Twilio SMS (for client reminders) ──────────────────
# Your Twilio phone number for outbound SMS
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── Company settings ────────────────────────────────────
# Used in SMS messages and notifications
COMPANY_REVIEW_LINK=https://g.page/r/your-google-review-link

# ── Vapi Phone Number ID ────────────────────────────────
# dashboard.vapi.ai → Phone Numbers → copy the ID
VAPI_PHONE_NUMBER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
