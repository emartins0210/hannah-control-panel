# Fabíola Services - Configuração de Ambiente
# Copie este arquivo para .env e preencha os valores

# Servidor
PORT=3000
NODE_ENV=development

# JWT Authentication
# ⚠️ CRITICAL: Gere um novo JWT_SECRET seguro usando:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=seu_secret_super_seguro_MUDE_AQUI_123456789

# Banco de Dados (se usar no futuro)
# DATABASE_URL=

# Email (opcional - para notificações)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu_email@gmail.com
# SMTP_PASS=sua_senha_app

# Twilio (opcional - para WhatsApp)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Ambiente de Produção
# NODE_ENV=production
# JWT_SECRET=<gere_um_novo_aqui>
# PORT=3000
